      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "single" } },
      "title": "Gateway — Request Rate",
      "type": "timeseries",
      "targets": [{ "expr": "rate(http_requests_total{job=\"gateway\"}[5m])", "legendFormat": "{{method}} {{path}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 500 }] }, "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }, "id": 2,
      "options": { "orientation": "auto", "showThresholdLabels": false },
      "title": "Gateway — Response Latency (p95)",
      "type": "gauge",
      "targets": [{ "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"gateway\"}[5m]))*1000", "legendFormat": "p95" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 30, "lineWidth": 2, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 }, "id": 3,
      "title": "AI Workers — Task Processing Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(tasks_processed_total{job=\"workers\"}[5m])", "legendFormat": "{{agent_type}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 }, "id": 4,
      "title": "Active Users (WS)",
      "type": "stat",
      "targets": [{ "expr": "websocket_connections_active{job=\"gateway\"}", "legendFormat": "Connected" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 }, "id": 5,
      "title": "Tasks Queued",
      "type": "stat",
      "targets": [{ "expr": "rabbitmq_queue_messages{vhost=\"ai_os_vhost\"}", "legendFormat": "{{queue}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 }, "id": 6,
      "title": "Task Success Rate",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(tasks_completed_total[5m])) / sum(rate(tasks_processed_total[5m])) * 100", "legendFormat": "Success %" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 }, "id": 7,
      "title": "Failed Tasks (DLQ)",
      "type": "stat",
      "targets": [{ "expr": "sum(rabbitmq_queue_messages{queue=~\".*dlq.*\",vhost=\"ai_os_vhost\"})", "legendFormat": "DLQ Messages" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 }, "id": 8,
      "title": "Database — Active Connections",
      "type": "timeseries",
      "targets": [
        { "expr": "pg_stat_activity_count{datname=\"ai_os_db\"}", "legendFormat": "PostgreSQL" },
        { "expr": "mongodb_connections_current", "legendFormat": "MongoDB" },
        { "expr": "redis_connected_clients", "legendFormat": "Redis" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 }, "id": 9,
      "title": "System — Memory & CPU",
      "type": "timeseries",
      "targets": [
        { "expr": "process_resident_memory_bytes{job=\"gateway\"} / 1024 / 1024", "legendFormat": "Gateway RAM (MB)" },
        { "expr": "rate(process_cpu_seconds_total{job=\"gateway\"}[5m]) * 100", "legendFormat": "Gateway CPU %" }
      ]
    }
