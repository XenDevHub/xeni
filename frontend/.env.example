# ============================================================
# XENI AI — E-Commerce Command Center
# Next.js Frontend Environment Variables
# ============================================================
# Copy to .env.local and fill in values
# ============================================================

# ── API ──
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# ── Google OAuth ──
NEXT_PUBLIC_GOOGLE_CLIENT_ID=755475680976-oo4momhgut4c8l6ttqlqp1h46n6oi7cc.apps.googleusercontent.com

# ── Facebook OAuth (seller login) ──
NEXT_PUBLIC_FACEBOOK_APP_ID=1624183118791170

# ── Firebase Cloud Messaging ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── i18n ──
NEXT_PUBLIC_DEFAULT_LOCALE=bn
