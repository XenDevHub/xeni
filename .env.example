# ============================================================
# XENI AI — Autonomous E-Commerce Command Center
# Root Environment Variables
# ============================================================
# Copy to .env and fill in values
# Used by docker-compose for infrastructure services
# ============================================================

# ── PostgreSQL ──
POSTGRES_USER=xeni
POSTGRES_PASSWORD=xeni_secret
POSTGRES_DB=xeni_db

# ── MongoDB ──
MONGO_USER=xeni
MONGO_PASSWORD=xeni_secret

# ── Redis ──
REDIS_PASSWORD=xeni_secret

# ── RabbitMQ ──
RABBITMQ_USER=xeni
RABBITMQ_PASSWORD=xeni_secret

# ── Grafana ──
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
