# ============================================================
# XENI AI — Autonomous E-Commerce Command Center
# Root Environment Variables
# ============================================================
# Copy to .env and fill in values
# Used by docker-compose for infrastructure services
# ============================================================

# ── PostgreSQL ──
POSTGRES_USER=xeni
POSTGRES_PASSWORD=xeni_secret
POSTGRES_DB=xeni_db

# ── MongoDB ──
MONGO_USER=xeni
MONGO_PASSWORD=xeni_secret

# ── Redis ──
REDIS_PASSWORD=xeni_secret

# ── RabbitMQ ──
RABBITMQ_USER=xeni
RABBITMQ_PASSWORD=xeni_secret

# ── Grafana ──
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
# ── Meta (Facebook/WhatsApp) ──
META_APP_SECRET=
FACEBOOK_WEBHOOK_VERIFY_TOKEN=
META_PAGE_API_VERSION=v19.0
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_ACCESS_TOKEN=
