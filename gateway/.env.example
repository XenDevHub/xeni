# ============================================================
# XENI Gateway — Environment Variables Template
# ============================================================
# Copy to .env and fill in values
# Go Fiber API Gateway for the E-Commerce Command Center
# ============================================================

APP_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:3000

# ── Database ──
POSTGRES_URI=postgres://xeni:xeni_secret@localhost:5432/xeni_db?sslmode=disable

# ── Redis ──
REDIS_URI=redis://:xeni_secret@localhost:6379/0

# ── RabbitMQ ──
RABBITMQ_URI=amqp://xeni:xeni_secret@localhost:5672/xeni_vhost

# ── JWT ──
JWT_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# ── Google OAuth ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Facebook OAuth (seller login + Page connection) ──
FACEBOOK_APP_ID=1650750519573355
FACEBOOK_APP_SECRET=a88ba177fda7fe9a5d22a35953ae3264

# ── Meta Messenger Webhook ──
FACEBOOK_WEBHOOK_VERIFY_TOKEN=xeni_webhook_2024_secret
META_APP_SECRET=a88ba177fda7fe9a5d22a35953ae3264

# ── Facebook Page Token Encryption (AES-256 key — 32 bytes hex) ──
PAGE_TOKEN_ENCRYPTION_KEY=2efe5d4e456807e2b347e1e71ca2597c6f9d8f159aea4e05dc68ac3b08bd7a93

# ── SSLCommerz (Bangladesh — BDT only) ──
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_SANDBOX=true

# ── Courier APIs ──
PATHAO_API_BASE_URL=https://api-hermes.pathao.com
PATHAO_CLIENT_ID=
PATHAO_CLIENT_SECRET=
PATHAO_USERNAME=
PATHAO_PASSWORD=
STEADFAST_API_BASE_URL=https://portal.steadfast.com.bd/api/v1
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=

# ── Mobile Financial Services ──
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_IS_SANDBOX=true
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_KEY=
NAGAD_IS_SANDBOX=true

# ── Resend Email ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@xeni.ai

# ── Firebase Cloud Messaging ──
FCM_SERVER_KEY=

# ── Rate Limiting ──
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60s
