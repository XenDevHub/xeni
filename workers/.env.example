# ============================================================
# XENI AI Workers — Environment Variables Template
# ============================================================
# Copy to .env and fill in values
# Shared across all 5 e-commerce agent workers
# Per-worker overrides via docker-compose (AGENT_TYPE, TASK_QUEUE, etc.)
# ============================================================

# ── MongoDB ──
MONGO_URI=mongodb://xeni:xeni_secret@mongodb:27017/xeni_outputs?authSource=admin

# ── RabbitMQ ──
RABBITMQ_URI=amqp://xeni:xeni_secret@rabbitmq:5672/xeni_vhost

# ── LLM API Keys ──
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Resend Email ──
RESEND_API_KEY=re_...

# ── Firebase Cloud Messaging ──
FCM_SERVER_KEY=

# ── AWS S3 / Cloudflare R2 (product images, screenshots, reports) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=xeni-assets
AWS_S3_REGION=ap-southeast-1

# ── Facebook Graph API (used by Conversation & Creative workers) ──
META_GRAPH_API_VERSION=v19.0

# ── Courier APIs (used by Order worker) ──
PATHAO_API_BASE_URL=https://api-hermes.pathao.com
STEADFAST_API_BASE_URL=https://portal.steadfast.com.bd/api/v1

# ── MFS Payment Verification (used by Order worker) ──
BKASH_VERIFY_API_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
NAGAD_VERIFY_API_URL=https://api.mynagad.com

# ── Worker Config (overridden per container in docker-compose) ──
TASK_QUEUE=conversation_tasks
RESULT_QUEUE=task_results
DLQ_NAME=conversation_tasks_dlq
MAX_RETRIES=3
PORT=8001
